<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>lab-create</title>
  <link rel="stylesheet" href="/static/style.css">
  <!-- Scripts vendored in /static/ — no external CDN dependency (F-5). -->
  <script src="/static/htmx.min.js"></script>
  <script src="/static/sse.js"></script>
</head>
<!-- W3: every HTMX request carries the per-process CSRF token; the
     state-changing routes verify it (see routes/actions.py _csrf_guard). -->
<body hx-headers='{"X-CSRFToken": "{{ csrf_token }}"}'>

<header>
  <span class="brand">lab-create</span>
  <span class="subtitle">resource browser</span>
  <nav>
    <a href="/api/v1/resources" target="_blank">JSON API</a>
  </nav>
</header>

<div id="layout">

  <!-- ── left pane: resource tree ─────────────────────────────────── -->
  <aside id="tree-pane">
    <div class="pane-title">Resources
      <button class="btn-sm"
              hx-get="/partials/resources"
              hx-target="#resource-tbody"
              hx-swap="innerHTML"
              title="Refresh">↺</button>
    </div>
    <table id="resource-table">
      <thead>
        <tr>
          <th>name</th>
          <th>type</th>
          <th>status</th>
        </tr>
      </thead>
      <tbody id="resource-tbody"
             hx-get="/partials/resources"
             hx-trigger="load, every 10s"
             hx-swap="innerHTML">
        <tr><td colspan="3" class="loading">loading…</td></tr>
      </tbody>
    </table>

    {% if unavailable %}
    <div class="unavailable-list">
      <span class="dim">unavailable:</span>
      {% for b in unavailable %}<span class="unavailable-badge">{{ b }}</span>{% endfor %}
    </div>
    {% endif %}
  </aside>

  <!-- ── right pane: detail / inspect ─────────────────────────────── -->
  <main id="detail-panel">
    <div class="empty-detail">
      <p>Select a resource to inspect.</p>
      <p class="dim">Press the refresh button or wait for the auto-poll (every 10 s).</p>
    </div>
  </main>

</div><!-- #layout -->

</body>
</html>
