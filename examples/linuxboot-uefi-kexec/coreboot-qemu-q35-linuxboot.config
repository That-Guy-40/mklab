# coreboot config fragment — QEMU q35 board + the LinuxBoot payload.
# build-coreboot.sh copies this to coreboot/.config and runs `make olddefconfig`,
# which fills in every other symbol's default. Verified at coreboot e95bdb7e.
#
# The payload is built BY coreboot: it downloads linux-6.3, compiles it with the
# shipped minimal x86_64 defconfig (serial console + kexec + initrd), builds u-root
# v0.14.0 from source as the initramfs, and embeds the result as the CBFS payload.

CONFIG_BOARD_EMULATION_QEMU_X86_Q35=y
CONFIG_COREBOOT_ROMSIZE_KB_16384=y          # 16 MB ROM — room for the kernel+u-root payload

CONFIG_PAYLOAD_LINUXBOOT=y                  # the LinuxBoot external payload
CONFIG_LINUXBOOT_X86_64=y
CONFIG_LINUXBOOT_COMPILE_KERNEL=y           # coreboot fetches + builds the kernel...
CONFIG_LINUXBOOT_KERNEL_VERSION="6.3"       # ...this version, with the shipped x86_64/defconfig
CONFIG_LINUX_COMMAND_LINE="console=ttyS0"   # serial console so we see it under -nographic

CONFIG_LINUXBOOT_BUILD_INITRAMFS=y          # ...and builds u-root as the initramfs
CONFIG_LINUXBOOT_UROOT=y
CONFIG_LINUXBOOT_UROOT_CUSTOM=y
CONFIG_LINUXBOOT_UROOT_CHECKOUT="v0.14.0"   # pin a Go-1.22-buildable u-root (GOTOOLCHAIN=local)

# NOTE: the NETWORK boot policy (`pxeboot`) lives in a SEPARATE config —
# coreboot-qemu-q35-pxeboot.config — because it requires u-root *main* (Go 1.25):
# u-root v0.14.0's DHCP client emits no packets over QEMU slirp (fully diagnosed in
# POC-PXEBOOT.md). This config stays exactly as verified for Tiers A + the disk finale.
