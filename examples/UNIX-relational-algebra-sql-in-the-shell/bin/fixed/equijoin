#!/bin/bash
# equijoin (CORRECTED) — join rel1 and rel2 where col1 of rel1 == col2 of rel2.
#
#   equijoin [ -d <delim> | -t ] rel1 rel2 col1 col2
#
# Drop-in replacement for ../equijoin (Matt Might, "Relational shell
# programming").  A join is not a primitive: it is Cartesian product followed by
# selection on equality, and the body still shows exactly that.
#
# What changed, and why:
#   1. `-t` NOW WORKS (real tab via $'\t'; `printf` instead of `echo`) — the
#      original emitted a literal backslash-t, so every TSV join silently found
#      zero matching rows.  This is the erratum most likely to bite you, because
#      it fails QUIETLY: an empty result looks like "no rows matched".
#   2. `read -r` + `IFS=` + quoted paths — see ../fixed/cartesian.
#   3. `$( )` instead of backticks; the column arguments are validated as
#      integers before being interpolated into the awk program.  The original
#      pasted `$3`/`$4` straight into a double-quoted awk script.
#
# Still O(|rel1| x |rel2|) — it materializes the whole product before selecting.
# The native `join(1)` streams two SORTED inputs in O(n + m) and demo.sh proves
# the two return the same relation.  Turning this into a linear merge is the
# article's closing Exercise.

delim=","

usage() { echo "usage: ${0##*/} [ -d <delim> | -t ] rel1 rel2 col1 col2" >&2; exit 1; }

while getopts "td:" flag
do
  case $flag in
    d) delim=$OPTARG;;
    t) delim=$'\t';;
    *) usage;;
  esac
done
shift $((OPTIND - 1))

[ $# -eq 4 ] || usage
f1=$1
f2=$2
col1=$3
col2=$4
case $col1$col2 in *[!0-9]*) echo "${0##*/}: columns must be integers" >&2; exit 1;; esac
[ -r "$f1" ] && [ -r "$f2" ] || { echo "${0##*/}: cannot read input" >&2; exit 1; }

cols=$(awk -F "$delim" '{ print NF ; exit }' "$f1")

while IFS= read -r a
do
  while IFS= read -r b
  do
    printf '%s%s%s\n' "$a" "$delim" "$b"
  done < "$f2"
done < "$f1" |
  awk -F "$delim" -v c1="$col1" -v c2="$((col2 + cols))" '$c1 == $c2'
