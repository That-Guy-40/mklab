diff --git a/arch/x86/linux_load.c b/arch/x86/linux_load.c
index cfcb338..d2bb878 100644
--- a/arch/x86/linux_load.c
+++ b/arch/x86/linux_load.c
@@ -67,6 +67,28 @@ struct linux_header {
     uint32_t cmd_line_ptr;		/* 0x228 */
     /* 2.03+ */
     uint32_t initrd_addr_max;		/* 0x22c */
+    /* 2.05+ */
+    uint32_t kernel_alignment;		/* 0x230 */
+    uint8_t  relocatable_kernel;	/* 0x234 */
+    uint8_t  min_alignment;		/* 0x235 */
+    uint16_t xloadflags;		/* 0x236 */
+    /* 2.06+ */
+    uint32_t cmdline_size;		/* 0x238 */
+    /* 2.07+ */
+    uint32_t hardware_subarch;		/* 0x23c */
+    uint64_t hardware_subarch_data;	/* 0x240 */
+    /* 2.08+ */
+    uint32_t payload_offset;		/* 0x248 */
+    uint32_t payload_length;		/* 0x24c */
+    /* 2.09+ */
+    uint64_t setup_data;		/* 0x250 */
+    /* 2.10+ */
+    uint64_t pref_address;		/* 0x258 */
+    uint32_t init_size;			/* 0x260 */
+    /* 2.11+ */
+    uint32_t handover_offset;		/* 0x264 */
+    /* 2.15+ */
+    uint32_t kernel_info_offset;	/* 0x268 */
 } __attribute__ ((packed));
 
 
@@ -242,6 +264,15 @@ init_linux_params(struct linux_params *params, struct linux_header *hdr)
     debug("Setting up parameters at %#lx\n", virt_to_phys(params));
     memset(params, 0, sizeof *params);
 
+    /* Boot protocol 2.02+: the loader must copy the ENTIRE setup header
+     * into the zero page at 0x1f1 — modern kernels read fields this 2003
+     * loader never knew (kernel_alignment, init_size, pref_address...);
+     * leaving them zero sent the decompression stub's relocation math to
+     * a >4 GB stack (page fault in startup_64 before the first printk).
+     * Loader-owned fields are overwritten again below/later. */
+    memcpy((uint8_t *)params + 0x1f1, (uint8_t *)hdr + 0x1f1,
+           sizeof(*hdr) - 0x1f1);
+
     /* Copy some useful values from header */
     params->mount_root_rdonly = hdr->root_flags;
     params->orig_root_dev = hdr->root_dev;
@@ -580,6 +611,12 @@ static int start_linux(uint32_t kern_addr, struct linux_params *params)
 
     ctx = init_context(phys_to_virt(STACK_LOC), 4096, 0);
 
+    /* init_context() zeroes the frame; nobody ever set esp on this path
+     * (arch_init_program does it for the generic loaders). switch_to()
+     * pops the segment/flags/eip block from ctx->esp — with esp=0 it
+     * popped garbage and faulted before ever reaching the kernel. */
+    ctx->esp = virt_to_phys(ESP_LOC(ctx));
+
     /* Linux expects GDT being in low memory */
     linux_gdt = phys_to_virt(GDT_LOC);
     memset(linux_gdt, 0, 13*sizeof(struct segment_desc));
diff --git a/arch/x86/multiboot.h b/arch/x86/multiboot.h
index fd0fe97..920a561 100644
--- a/arch/x86/multiboot.h
+++ b/arch/x86/multiboot.h
@@ -10,8 +10,12 @@
 /* magic number for multiboot header */
 #define MULTIBOOT_HEADER_MAGIC		0x1BADB002
 
-/* flags for multiboot header */
-#define MULTIBOOT_HEADER_FLAGS		0x00010003
+/* flags for multiboot header.
+ * Bit 16 (AOUT_KLUDGE) must NOT be set: struct mbheader in multiboot.c
+ * carries no address fields, so a spec-compliant loader (QEMU -kernel,
+ * GRUB) would read zeros and load/jump to address 0. The image is a valid
+ * ELF; loaders use the program headers when bit 16 is clear. */
+#define MULTIBOOT_HEADER_FLAGS		0x00000003
 
 /* magic number passed by multiboot-compliant boot loader.  */
 #define MULTIBOOT_BOOTLOADER_MAGIC	0x2BADB002
