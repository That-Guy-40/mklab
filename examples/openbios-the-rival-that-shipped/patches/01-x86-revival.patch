+                static char intdict[1024 * 1024];
+                dict = (unsigned char *)intdict;
+                dictlimit = sizeof(intdict);
+                load_dictionary((char *)sys_info.dict_start,
+                                (char *)sys_info.dict_end
+                                - (char *)sys_info.dict_start);
+        }
 
 	forth_init();
 
diff --git a/forth/admin/nvram.fs b/forth/admin/nvram.fs
index 3fbd935..8d38c81 100644
--- a/forth/admin/nvram.fs
+++ b/forth/admin/nvram.fs
@@ -301,7 +301,14 @@ constant config-info.size
 \ NVRAM variables
 \ --------------------------------------------------------
 \ fcode-debug? input-device output-device
+\ x86: auto-boot is unconditional (main.fs has no interrupt window) and the
+\ post-probe boot attempt detonates when IDE media is attached — land at the
+\ ok prompt instead; boot is typed there. Other arches keep the 1275 default.
+[IFDEF] CONFIG_X86
+s" false"    s" auto-boot?"           bool-config   \ 7.4.3.5
+[ELSE]
 s" true"     s" auto-boot?"           bool-config   \ 7.4.3.5
+[THEN]
 s" boot"     s" boot-command"         str-config    \ 7.4.3.5
 s" "         s" boot-file"            str-config    \ 7.4.3.5
 s" false"    s" diag-switch?"         bool-config   \ 7.4.3.5
@@ -342,6 +349,10 @@ s" true"     s" vga-ndrv?"            bool-config
 [IFDEF] CONFIG_X86
 \ ---- X86 ----
 s" true"     s" little-endian?"       bool-config
+\ Every other arch defines load-base; x86 never did, so $load's
+\ `" load-base" evaluate` executed an undefined word and crashed the
+\ auto-boot path (GPF at pc=0) as soon as a disk was attached.
+s" 4000000"  s" load-base"            int-config
 [THEN]
 
 [IFDEF] CONFIG_SPARC32
