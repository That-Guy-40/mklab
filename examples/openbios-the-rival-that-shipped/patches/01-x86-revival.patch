diff --git a/arch/x86/boot.c b/arch/x86/boot.c
index 61f6562..23c299d 100644
--- a/arch/x86/boot.c
+++ b/arch/x86/boot.c
@@ -13,11 +13,33 @@
 #include "libc/diskio.h"
 #include "libopenbios/initprogram.h"
 #include "libopenbios/sys_info.h"
+#include "libc/string.h"
 #include "boot.h"
 
 
+/* The Linux/bzImage loader (linux_load.c) is compiled into this image but
+ * was never called from the x86 boot word — the call survives only in
+ * arch/amd64/boot.c (which still prints "[x86]": it is this arch's old
+ * boot code, moved there when amd64 split off). Ported back. */
 void boot(void)
 {
-	/* No platform-specific boot code */
-	return;
+	char *path=pop_fstr_copy(), *param;
+
+	if(!path) {
+		printk("[x86] Booting default not supported.\n");
+		return;
+	}
+
+	param = strchr(path, ' ');
+	if(param) {
+		*param = '\0';
+		param++;
+	}
+
+	printk("[x86] Booting file '%s' with parameters '%s'\n",path, param);
+
+	if (linux_load(&sys_info, path, param) == LOADER_NOT_SUPPORT)
+		printk("Unsupported image format\n");
+
+	free(path);
 }
