diff --git a/libopenbios/linuxbios_info.c b/libopenbios/linuxbios_info.c
index bef996c..d9ce7c5 100644
--- a/libopenbios/linuxbios_info.c
+++ b/libopenbios/linuxbios_info.c
@@ -109,9 +109,40 @@ static int find_lb_table(void *start, void *end, struct lb_header **result)
 	return 0;
 }
 
+/* Since ~2009 the table in low memory is only a stub whose single record
+ * (LB_TAG_FORWARD) points at the real table up in CBMEM. Without chasing
+ * it, read_lbtable() finds no LB_TAG_MEMORY and the caller falls back to
+ * the hardcoded 640K+31MB map — on any coreboot new enough to forward,
+ * this firmware thought every machine had 32 MB of RAM. */
+#define LB_TAG_FORWARD	0x0011
+struct lb_forward {
+	uint32_t tag;
+	uint32_t size;
+	uint64_t forward;
+};
+
+static int forward_lb_table(struct lb_header *head, struct lb_header **result)
+{
+	struct lb_record *rec;
+
+	for_each_lbrec(head, rec) {
+		if (rec->tag == LB_TAG_FORWARD) {
+			unsigned long addr;
+
+			addr = (unsigned long)
+				((struct lb_forward *) rec)->forward;
+			debug("Forwarding record -> %#lx\n", addr);
+			/* validate the forwarded location like any other */
+			return find_lb_table(phys_to_virt(addr),
+					     phys_to_virt(addr + 16), result);
+		}
+	}
+	return 0;
+}
+
 void collect_linuxbios_info(struct sys_info *info)
 {
-	struct lb_header *lb_table;
+	struct lb_header *lb_table, *fwd_table;
 	int found;
 	debug("Searching for LinuxBIOS tables...\n");
 	found = 0;
@@ -124,6 +155,9 @@ void collect_linuxbios_info(struct sys_info *info)
 	if (!found)
 		return;
 
+	if (forward_lb_table(lb_table, &fwd_table))
+		lb_table = fwd_table;
+
 	debug("Found LinuxBIOS table at: %p\n", lb_table);
 	info->firmware = "LinuxBIOS";
 	read_lbtable(lb_table, info);
