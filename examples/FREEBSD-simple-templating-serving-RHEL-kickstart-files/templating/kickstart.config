# kickstart.config — per-host parameters, sourced by kickstart.sh.
#
# Adapted from vermaden's RHEL-8.5 example to AlmaLinux 9 and this lab's single
# socket-LAN topology (vermaden used two interfaces; the second set of vars is
# kept but left unused by the shipped kickstart.skel — wire it back in if your
# target has a second NIC). Every NAME here is replaced wherever it appears in
# kickstart.skel by `sed -e s@NAME@${NAME}@g`.

# Target host identity
SYSTEM_NAME=kickme

# AlmaLinux release served by the FreeBSD nginx box
ALMA_MAJOR=9
ALMA_ARCH=x86_64
REPO_SERVER_IP=10.0.10.210

# Primary NIC (the lab LAN). enp0s3 is the first NIC's predictable name in the
# QEMU client; check yours with `ip link` if it differs.
INTERFACE1=enp0s3
IP_ADDRESS1=10.0.10.199
NETMASK1=255.255.255.0
GATEWAY=10.0.10.1

# Optional second NIC (unused by the shipped skel — vermaden's backup network)
INTERFACE2=enp0s8
IP_ADDRESS2=10.0.90.199
NETMASK2=255.255.255.0

# Resolvers + time sources
NAMESERVER1=1.1.1.1
NAMESERVER2=9.9.9.9
NTP1=132.163.97.6
NTP2=216.239.35.0
