diff --git a/arch/x86/openbios.c b/arch/x86/openbios.c
index 1274d2b..f891181 100644
--- a/arch/x86/openbios.c
+++ b/arch/x86/openbios.c
@@ -21,6 +21,13 @@
 #include "openbios.h"
 #include "relocate.h"
 #include "boot.h"
+#include "libc/vsprintf.h"
+#include "arch/x86/io.h"
+
+/* Where a loaded client/image lands, as a PHYSICAL address. 4 MiB is
+ * clear of low memory, the dictionary, and the firmware image (which
+ * relocates to the top of RAM). */
+#define LOAD_BASE_PHYS	0x400000
 
 void collect_sys_info(struct sys_info *info);
 
@@ -84,6 +91,32 @@ arch_init( void )
 #endif
 	device_end();
 	bind_func("platform-boot", boot );
+
+	/* x86 relocates itself by REBASING THE GDT data segment (see
+	 * arch/x86/segment.c), so every address Forth and the generic loaders
+	 * hand around is segment-relative: the CPU adds virt_offset to reach
+	 * physical memory. That makes a *constant* load-base wrong by
+	 * construction -- the 0x4000000 defined in forth/admin/nvram.fs
+	 * resolves to physical 0x4000000 + virt_offset, and since relocation
+	 * targets the TOP of RAM, virt_offset scales with memory size and the
+	 * result lands past the end of RAM. Loading a file into it looked like
+	 * it worked (the device read reported the full byte count) but every
+	 * byte went nowhere and load-base read back as zeros.
+	 *
+	 * arch/x86/linux_load.c dodges this by wrapping every access in
+	 * phys_to_virt() -- which is why the Linux boot path works and the
+	 * generic $load path did not. Give $load a load-base that is already
+	 * virtual. Defined here (not in nvram.fs) because only C knows
+	 * virt_offset; this shadows the nvram config word, which stays put so
+	 * that `" load-base" evaluate` still resolves if this ever regresses.
+	 */
+	{
+		char buf[64];
+		/* Forth's number base is hex here, matching nvram.fs's literals. */
+		snprintf(buf, sizeof(buf), "%lx constant load-base",
+			 (unsigned long)(uintptr_t)phys_to_virt(LOAD_BASE_PHYS));
+		feval(buf);
+	}
 }
 
 extern struct _console_ops arch_console_ops;
@@ -514,7 +514,19 @@ elf_init_program(void)
 #endif
 		/* Workaround for archs where sizeof(int) != pointer size */
 		tmp = phdr[i].p_vaddr;
+#ifdef CONFIG_X86
+		/* x86 relocates the firmware by rebasing the GDT data segment
+		 * (arch/x86/segment.c), so a raw p_vaddr is a *firmware-virtual*
+		 * address, not a physical one. Interpret the ELF's addresses as
+		 * physical and translate -- exactly as the elf-boot path above and
+		 * arch/x86/linux_load.c already do. Without this, a client linked
+		 * at 0x200000 is copied to 0x200000 + virt_offset, which lands
+		 * INSIDE the relocated firmware image and scribbles over the
+		 * running OpenBIOS (observed: general protection fault on `go`). */
+		addr = (char *)phys_to_virt(tmp);
+#else
 		addr = (char *)tmp;
+#endif
 
 		memcpy(addr, base + phdr[i].p_offset, size);
 
@@ -526,6 +538,12 @@ elf_init_program(void)
 	}
 
 	// Initialise load-state
+	/* NB x86: the entry point is NOT translated, unlike the segment copy
+	 * above. The copy is performed by the firmware, which runs with the
+	 * rebased data segment; the client is entered with FLAT, base-0
+	 * segments (see the client GDT used by switch_to_context), so it needs
+	 * the physical address. Translating it here jumped to eip 0xe046b092
+	 * and the CPU triple-faulted out of KVM. */
 	PUSH(ehdr->e_entry);
 	feval("load-state >ls.entry !");
 	
