diff --git a/arch/x86/context.c b/arch/x86/context.c
index 5ed3875..e83e309 100644
--- a/arch/x86/context.c
+++ b/arch/x86/context.c
@@ -16,6 +16,10 @@
 #include "boot.h"
 #include "openbios.h"
 
+/* The IEEE 1275 client-interface dispatcher (libopenbios/client.c). Compiled
+ * into every arch but, until now, never handed to a launched client on x86. */
+extern int of_client_interface(int *params);
+
 #define MAIN_STACK_SIZE 16384
 #define IMAGE_STACK_SIZE 4096
 
@@ -70,8 +74,10 @@ static void start_main(void)
 
     init_exceptions();
 
-    /* Set up client context */
-    client_ctx = init_context(image_stack, sizeof image_stack, 1);
+    /* Set up client context.
+     * 5 param slots: an IEEE 1275 client program is entered with five
+     * arguments on its stack — _start(residual, entry, cif, args, argslen). */
+    client_ctx = init_context(image_stack, sizeof image_stack, 5);
     __context = client_ctx;
 
     /* Start the real fun */
@@ -135,6 +141,51 @@ arch_init_program(void)
     entry = POP();
     ctx->eip = entry;
 
+    /* IEEE 1275 client program (a plain ELF, file-type 'elf' = 1, as opposed
+     * to an 'elf-boot' Linux/multiboot image = 0): hand it the client-interface
+     * callback. PPC passes it in r5 (see arch/ppc/qemu/context.c); x86 has no
+     * such register convention, so we lay the five client-entry arguments on
+     * the client stack where its _start(residual, entry, cif, args, argslen)
+     * reads them. param[0..4] sit just above return_addr per ESP_LOC, so on
+     * entry the client sees them as its C arguments 1..5. */
+    if (type == 1) {
+        /* Enter the client with the firmware's RELOCATED segments, not the
+         * flat ones an elf-boot image gets. x86 relocates OpenBIOS by rebasing
+         * the GDT (arch/x86/segment.c), so firmware pointers are
+         * segment-relative; running the client in that same segment space
+         * makes every pointer it hands back through the client interface
+         * directly usable by the firmware.
+         *
+         * The alternative -- flat segments plus a switching trampoline -- is a
+         * dead end here: of_client_interface() pushes pb->args[] straight onto
+         * the Forth stack, and *which* of those args are pointers depends on
+         * the service being called. There is no generic place to translate
+         * them, so a flat client would need the whole dispatcher rewritten.
+         *
+         * Cost of this choice: the client must be linked into the virtual
+         * window below _start (0x100010), which maps to physical memory just
+         * below the relocated firmware. That window tracks RAM size
+         * automatically, because both ends move with virt_offset.
+         */
+        ctx->cs = RELOC_CS;
+        ctx->ds = RELOC_DS;
+        ctx->es = RELOC_DS;
+        ctx->fs = RELOC_DS;
+        ctx->gs = RELOC_DS;
+        ctx->ss = RELOC_DS;
+        /* ...so the stack and return address stay VIRTUAL (the flat-model
+         * defaults above ran them through virt_to_phys). gdt_base stays
+         * physical either way -- lgdt always takes a linear address. */
+        ctx->esp = (uint32_t)(uintptr_t)ESP_LOC(ctx);
+        ctx->return_addr = (uint32_t)(uintptr_t)__exit_context;
+
+        ctx->param[0] = 0;                                   /* residual data */
+        ctx->param[1] = entry;                               /* program entry */
+        ctx->param[2] = (ucell)(uintptr_t)of_client_interface; /* the CIF */
+        ctx->param[3] = 0;                                   /* args string   */
+        ctx->param[4] = 0;                                   /* args length   */
+    }
+
     return 0;
 }
 
