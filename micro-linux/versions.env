# versions.env — pinned inputs + trust anchors for mlbuild.sh
#
# This file is SOURCED by mlbuild.sh (treat it as code, not data — AUDIT F3).
# It pins the *durable* trust anchors: upstream versions and PGP key
# FINGERPRINTS.  Per-version content hashes are NOT pinned here — they are
# auto-derived into versions.lock on the first verified build (see plan §6.0).
#
# Trust model (plan §6.0 / §8): authenticity comes from a signature made by a
# key we vendored OUT-OF-BAND (keys/, fingerprints below), never from a
# checksum fetched alongside the tarball.  See keys/README.md.

# ── Upstream versions ────────────────────────────────────────────────────────
# Example pins — bump to a current LTS/release and re-verify per keys/README.md.
LINUX_VER=6.12.30          # a 6.12.x LTS
LINUX_MAJOR=v6.x           # cdn.kernel.org path component
BUSYBOX_VER=1.36.1         # NOTE: tc.c needs the CONFIG_TC disable vs kernel >=6.8; 1.37.0 fixes it
UROOT_REF=v0.14.0          # faithful track (§11); Go-module ref, integrity via go.sum
GO_VER=1.22.5              # faithful track; Go toolchain (see Containerfile)

# ── PGP keyrings (vendored) + the fingerprint each MUST contain ──────────────
# Paths are relative to micro-linux/.  Fingerprints are 40 hex chars, no spaces.
# Obtain + verify these out-of-band, then paste the fingerprint here. mlbuild.sh
# refuses to build until they are real (the PIN-ME sentinel fails closed).
KERNEL_KEYRING=keys/kernel.gpg
KERNEL_FPR=PIN-ME-kernel-org-stable-release-signer-fingerprint
BUSYBOX_KEYRING=keys/busybox.gpg
BUSYBOX_FPR=PIN-ME-busybox-release-signer-fingerprint

# ── Container base image — PIN BY DIGEST (AUDIT F5) ──────────────────────────
# Leaving the bare tag works but tracks upstream drift. To pin:
#   skopeo inspect docker://debian:bookworm-slim --format '{{.Digest}}'
# then set: BASE_IMAGE="debian:bookworm-slim@sha256:<digest>"
BASE_IMAGE="debian:bookworm-slim"
